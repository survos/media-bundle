{#
  MediaShow — generic show page for any entity implementing EnrichmentInterface + MediaSyncInterface.

  Slots (override via anonymous component blocks):
    app_header   — workflow strip, badges, action buttons, etc.
    app_sections — app-specific cards injected below the Source Record (tags, OCR columns, etc.)

  Props: see MediaShow.php
#}
{% set mediaSync = this.mediaSync() %}
{% set sourceMeta = this.sourceMeta() %}
{% set tabId = 'ms-' ~ random() %}

{# ── app header slot ─────────────────────────────────────────────────────── #}
{% block app_header %}{% endblock %}

<div class="row g-4">

  {# ══ LEFT: image + metadata ════════════════════════════════════════════════ #}
  <div class="col-12 col-lg-5">

    {# Image card #}
    <div class="card mb-3">
      <div class="card-body p-0">
        {% if this.hasImage() %}
          <a href="{{ this.fullSizeUrl() }}" target="_blank" rel="noopener">
            <img src="{{ this.imageUrl }}"
                 alt="{{ this.imageAlt }}"
                 class="img-fluid w-100 d-block"
                 style="max-height:520px; object-fit:contain; background:#111; cursor:zoom-in;"
                 loading="lazy">
          </a>
        {% else %}
          <div class="text-center text-muted py-5">
            {{ ux_icon('mdi:image-off', {height: '48px', width: '48px'}) }}
            <div class="small mt-2">No image available</div>
          </div>
        {% endif %}
      </div>
      {% if this.hasImage() %}
        <div class="card-footer d-flex justify-content-between align-items-center py-1 flex-wrap gap-2">
          <div class="d-flex gap-3">
            {% if this.iiifBase %}
              <a href="{{ this.iiifBase }}/info.json" target="_blank" rel="noopener" class="small text-muted">IIIF info ↗</a>
            {% elseif this.iiifInfoUrl %}
              <a href="{{ this.iiifInfoUrl }}" target="_blank" rel="noopener" class="small text-muted">IIIF info ↗</a>
            {% endif %}
            {% if mediaSync and mediaSync.iiifManifest %}
              <a href="{{ mediaSync.iiifManifest }}" target="_blank" rel="noopener" class="small text-muted">Manifest ↗</a>
            {% endif %}
          </div>
          {% if this.fullSizeUrl() %}
            <a href="{{ this.fullSizeUrl() }}" target="_blank" rel="noopener" class="small">Full size ↗</a>
          {% endif %}
        </div>
      {% endif %}
      {# Compact title/description below image — no scrolling needed #}
      {% set displayTitle = mediaSync.title ?? this.imageAlt %}
      {% set displayDesc  = mediaSync.description ?? null %}
      {% if displayTitle or displayDesc %}
        <div class="card-body border-top py-2 small">
          {% if displayTitle %}<div class="fw-semibold">{{ displayTitle }}</div>{% endif %}
          {% if displayDesc %}<div class="text-muted mt-1">{{ displayDesc }}</div>{% endif %}
        </div>
      {% endif %}
    </div>

    {# app-specific left-column sections #}
    {% block app_sections %}{% endblock %}

  </div>{# /col-lg-5 #}

  {# ══ RIGHT: tabbed AI/metadata panel ══════════════════════════════════════ #}
  <div class="col-12 col-lg-7">

    {# Tabbed card #}
    <div class="card">
      <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" id="{{ tabId }}-nav" role="tablist">
          <li class="nav-item">
            <a href="#{{ tabId }}-ocr"
               class="nav-link {{ activeTab == 'ocr' ? 'active' : '' }}"
               data-bs-toggle="tab" data-tab-id="ocr">Text</a>
          </li>
          <li class="nav-item">
            <a href="#{{ tabId }}-summary"
               class="nav-link {{ activeTab == 'summary' ? 'active' : '' }}"
               data-bs-toggle="tab" data-tab-id="summary">Summary</a>
          </li>
          <li class="nav-item">
            <a href="#{{ tabId }}-tags"
               class="nav-link {{ activeTab == 'tags' ? 'active' : '' }}"
               data-bs-toggle="tab" data-tab-id="tags">Tags</a>
          </li>
          <li class="nav-item">
            <a href="#{{ tabId }}-source"
               class="nav-link {{ activeTab == 'source_metadata' ? 'active' : '' }}"
               data-bs-toggle="tab" data-tab-id="source_metadata">Source Metadata</a>
          </li>
          {% if workflowCode %}
          <li class="nav-item">
            <a href="#{{ tabId }}-workflow"
               class="nav-link {{ activeTab == 'workflow' ? 'active' : '' }}"
               data-bs-toggle="tab" data-tab-id="workflow">Workflow</a>
          </li>
          {% endif %}
          <li class="nav-item">
            <a href="#{{ tabId }}-claims"
               class="nav-link {{ activeTab == 'claims' ? 'active' : '' }}"
               data-bs-toggle="tab" data-tab-id="claims">Claims</a>
          </li>
        </ul>
      </div>
      <div class="card-body">
        <div class="tab-content">

          {# Text — OCR/HTR claims consolidated from the claims table. #}
          <div id="{{ tabId }}-ocr" class="tab-pane {{ activeTab == 'ocr' ? 'active show' : '' }}" role="tabpanel">
            <twig:OcrClaimsPanel :subject="this.entity"/>
          </div>

          {# Summary — best-guess projection derived from claims only. #}
          <div id="{{ tabId }}-summary" class="tab-pane {{ activeTab == 'summary' ? 'active show' : '' }}" role="tabpanel">
            <twig:ClaimsSummary :subject="this.entity"/>
          </div>

          {# Tags — chip view of subject-like claims (keywords, people, places, speculations).
             Confidence: high (green, no suffix), medium (amber, ?), low (gray, ??) — matches
             the uncertainty convention in the triage prompt. Basis prints inline so the
             operator can see *why* each tag was proposed. #}
          <div id="{{ tabId }}-tags" class="tab-pane {{ activeTab == 'tags' ? 'active show' : '' }}" role="tabpanel">
            <twig:ClaimsList
              :subject="this.entity"
              predicates="dcterms:subject,foaf:Person,dcterms:spatial,ai:speculation"
              layout="chips"
            />
          </div>

          {# Source Metadata — claims written by the import pipeline (source ends with @import) #}
          <div id="{{ tabId }}-source" class="tab-pane {{ activeTab == 'source_metadata' ? 'active show' : '' }}" role="tabpanel">
            <twig:ClaimsList :subject="this.entity" sourceSuffix="@import" />
          </div>

          {# Workflow — transition controls and pending-steps queue #}
          {% if workflowCode %}
          <div id="{{ tabId }}-workflow" class="tab-pane {{ activeTab == 'workflow' ? 'active show' : '' }}" role="tabpanel">
            <twig:state:workflow-marking
              :subject="this.entity"
              globalKey="{{ globalKey }}"
              workflowCode="{{ workflowCode }}"
              redirectUrl="{{ app.request.uri }}"
              layout="table"
            />
          </div>
          {% endif %}

          {# Claims — audit/debug view. Bulky text claims live in the Text tab. #}
          <div id="{{ tabId }}-claims" class="tab-pane {{ activeTab == 'claims' ? 'active show' : '' }}" role="tabpanel">
            <twig:ClaimsList
              :subject="this.entity"
              excludePredicates="ai:ocrText,ai:htrText,ai:printedText"
            />
          </div>

        </div>{# /tab-content #}
      </div>{# /card-body #}
    </div>{# /card #}

    {# Hash-routing: activate tab from URL fragment, persist on tab change #}
    <script>
    (function () {
      var nav = document.getElementById({{ (tabId ~ '-nav')|json_encode|raw }});
      if (!nav) return;
      var hash = location.hash.slice(1);
      if (hash) {
        var link = nav.querySelector('[data-tab-id="' + hash + '"]');
        if (link) link.click();
      }
      nav.addEventListener('shown.bs.tab', function (e) {
        var id = e.target.getAttribute('data-tab-id');
        if (id) history.replaceState(null, '', '#' + id);
      });
    })();
    </script>

  </div>{# /col-lg-7 #}
</div>{# /row #}
