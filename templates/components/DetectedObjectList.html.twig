{#
  DetectedObjectList — objects grouped by label, each a cropped thumbnail of its
  region plus confidence. Companion to BoundingBoxImage. See BoundingBoxNormalizer.
#}
{% set groups = this.groups() %}
{% if groups is empty %}
  <div class="text-muted small">No objects detected.</div>
{% else %}
  <div class="vstack gap-3">
    {% for group in groups %}
      <div>
        <div class="text-uppercase text-muted small fw-semibold mb-2">
          {{ group.label }} <span class="text-secondary">({{ group.count }})</span>
        </div>
        <div class="d-flex flex-wrap gap-2">
          {% for item in group.items %}
            <figure class="m-0 text-center" title="{{ group.label }}{% if item.confPct is not null %} · {{ item.confPct }}%{% endif %}">
              <div style="width:{{ this.thumbWidth(item.crop.aspect) }}px; height:{{ this.thumbHeight }}px;
                          background-image:url('{{ this.src }}'); background-repeat:no-repeat;
                          background-size:{{ item.crop.size }}; background-position:{{ item.crop.pos }};
                          border:2px solid {{ item.color }}; border-radius:3px; background-color:#111;"></div>
              {% if item.confPct is not null %}
                <figcaption class="small mt-1" style="color:{{ item.color }}; font-weight:600;">{{ item.confPct }}%</figcaption>
              {% endif %}
            </figure>
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
